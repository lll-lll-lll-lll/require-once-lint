{
    "name": "depone/depone",
    "description": "A static analysis tool for PHP that helps you eliminate require_once-related issues.",
    "type": "library",
    "keywords": ["static analysis", "require-once", "autoload", "composer", "cli"],
    "homepage": "https://github.com/lll-lll-lll-lll/depone",
    "license": "MIT",
    "authors": [
        {
            "name": "lll-lll-lll-lll"
        }
    ],
    "support": {
        "issues": "https://github.com/lll-lll-lll-lll/depone/issues",
        "source": "https://github.com/lll-lll-lll-lll/depone"
    },
    "require": {
        "php": "^8.1",
        "symfony/console": "^6.4 || ^7.0 || ^8.0",
        "composer-runtime-api": "^2.1",
        "nikic/php-parser": "^5.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0 || ^13.2",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.66"
    },
    "autoload": {
        "psr-4": {
            "Depone\\Internal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depone\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/depone"
    ],
    "scripts": {
        "test": "vendor/bin/phpunit -c phpunit.xml.dist",
        "analyse": "vendor/bin/phpstan analyse",
        "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff --verbose --sequential",
        "cs-fix": "vendor/bin/php-cs-fixer fix --verbose --sequential",
        "check": [
            "@cs",
            "@analyse",
            "@test"
        ]
    }
}
